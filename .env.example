# Copy this file to `.env` and fill in only what you need.
#
# Local mode (`make start`) uses the bundled MongoDB replica set from
# `docker-compose.local.yml`, so `MONGODB_URI` is only required for Atlas mode.

# Required for `make start DB=atlas`
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>/?retryWrites=true&w=majority"

# Optional override. Defaults to `vissr-integration`.
DATABASE_NAME="vissr-integration"

# Runtime values such as PROFILE, DB, NUM_VEHICLES, VEHICLE_VINS,
# VSS_JSON_PATH, VSS_JSON_ROOT_DIR, and VEHICLE_DEFINITIONS_B64 are
# generated automatically by the Makefile and should not be added here.
