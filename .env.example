# Copy this file to `.env`.
#
# Local Docker runs are handled automatically by the make/docker-compose setup.
# For Atlas or any other external MongoDB deployment, set `MONGODB_URI` accordingly.
MONGODB_URI=mongodb://mongodb:27017/?directConnection=true
DATABASE_NAME=vissr-integration

# Examples:
# Local process on your machine: mongodb://localhost:27017/?directConnection=true
# Docker local demo (handled automatically by `make start`): mongodb://mongodb:27017/?directConnection=true
# Atlas: mongodb+srv://...

# Frontend runtime defaults for the single-vehicle ZOD profile.
VSS_JSON_PATH=/data/zod_vss.json
MQTT_VIN=MDBAX9C12XYZ1234

# Optional VIN bootstrap list.
# Runtime discovery now comes from MongoDB first; this is only used until vehicles publish.
VEHICLE_VINS=MDBAX9C12XYZ1234

# Generated automatically by the make workflow for dynamic vehicle metadata.
VEHICLE_DEFINITIONS_B64=
