# Copy this file to `.env` for local development.

# Shared MongoDB settings for the frontend and MQTT bridge.
MONGODB_URI=mongodb://mongodb:27017/vissr-integration?replicaSet=rs0
DATABASE_NAME=vissr-integration

# Frontend runtime configuration.
VSS_JSON_PATH=/data/zod_vss.json
MQTT_VIN=MDBAX9C12XYZ1234

# Deployment VIN allowlist for the bridge and frontend vehicle selector.
# Only VINs listed here and present in vehicle_status will be shown in the UI.
VEHICLE_VINS=MDBAX9C12XYZ1234
