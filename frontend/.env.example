# -----------------------------------------------------------------------------
# Frontend environment variables
#
# Copy this file to `.env.local` (preferred for local dev) and fill in values.
# Next.js automatically loads `.env.local` / `.env` from this directory when
# you run `npm run dev`.
#
#   cp .env.example .env.local
#   npm run dev
# -----------------------------------------------------------------------------

# --- MongoDB ----------------------------------------------------------------
# Connection string for the MongoDB deployment the app reads/writes against.
# For a local replica set started via docker-compose use the host port (27017).
# For Atlas, paste the SRV connection string (keep credentials out of git).
MONGODB_URI=mongodb://localhost:27017/?replicaSet=rs0

# Name of the database that holds the VISSR-ingested collections.
DATABASE_NAME=vissr-integration

# Optional MongoDB client tuning (milliseconds). Defaults shown.
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
# MONGODB_CONNECT_TIMEOUT_MS=10000

# --- Vehicles / VSS catalogue -----------------------------------------------
# Comma-separated list of VINs the UI should surface. The first entry is also
# used as the default VIN for the sandbox / single-vehicle flows.
VEHICLE_VINS=MDBAX9C12XYZ1234

# Back-compat alias used by some call sites if VEHICLE_VINS is unset.
MQTT_VIN=MDBAX9C12XYZ1234

# Path (served from the frontend's public/ directory) to the VSS JSON catalogue
# used to resolve VISS signal metadata. Default matches the bundled file.
VSS_JSON_PATH=/data/zod_vss.json

# Absolute directory the server uses to resolve VSS_JSON_PATH on disk.
# In dev this defaults to `<frontend>/public`, so you usually don't need it.
# VSS_JSON_ROOT_DIR=

# Optional base64-encoded JSON blob of per-vehicle overrides
# (make, model, VSS path, etc.). Leave empty for the defaults.
# VEHICLE_DEFINITIONS_B64=

# --- Branding ---------------------------------------------------------------
# Switches the UI brand/copy. Use `truck` for the connected-vehicles demo,
# anything else falls back to the default profile.
PROFILE=truck

# --- VISS WebSocket server actions ------------------------------------------
# Controls how the server action materialises VISS WebSocket responses.
# Defaults to "app". Leave unset unless you know you need to change it.
# WEBSOCKET_MATERIALIZATION_MODE=app
